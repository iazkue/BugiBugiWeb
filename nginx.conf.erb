worker_processes 1;
daemon off;

events {
    worker_connections 1024;
}

http {
    include mime.types;
    sendfile on;
    default_type application/octet-stream;

    server {
        listen <%= ENV["PORT"] %>;
        server_name _;
        root /app;
        index index.html;

        location / {
            try_files $uri $uri/ /index.html;
        }
    }
}
